//Take an input and create a slice.
//NOTE :  Here you cannot use the scanner function and bufio as it read the input in string so here we will use
//for loop and append the element in the slice.

package main
import "fmt"

func main() {
      
      //input the length of slice
      var num int
      fmt.Print("Enter the number of elements: ")
      fmt.Scan(&num)   
      
      
      // Declare the Slice
      arr := make([]int,0,num)           //slice declaration
      fmt.Printf("Enter the %d element in seq :", num)   //No of element

      for i:=0;i<num;i++{
          var element int
          fmt.Scan(&element)
          arr = append(arr,element)      
      }
      
      fmt.Print("Input Slice: ",arr )
