//2. Write a program to prompt the user to enter a name, and print “Hello <name>”. 
//Replace “<name>” with the text entered by a user running the program. [Scan function, 2 hours]

package main
import "fmt"
import "bufio"
import "os"

func main(){
    
    var name string
    fmt.Print("Enter the name : ")
    
    //scan multiple words
    scanner := bufio.NewScanner(os.Stdin)   //1 
    scanner.Scan()                          //2
    name = scanner.Text()                   //3
    
    //Function call and output return
    fmt.Printf("Hello "+name)
    
}
